# -----------------------------------------------------------------------------
# SHOUJIKI BACKEND (API) CONFIGURATION
# -----------------------------------------------------------------------------

# --- Database ---
# Local Docker default: postgresql+asyncpg://shoujiki:shoujiki_v3_secure_db_2026@db:5432/shoujiki
# Production: Use a managed PostgreSQL instance (Supabase, Neon, etc.)
DATABASE_URL=postgresql+asyncpg://shoujiki:shoujiki_v3_secure_db_2026@db:5432/shoujiki

# --- Redis (Split Queue and PubSub) ---
# For local Docker, use the service names 'redis-queue' and 'redis-pubsub'
REDIS_QUEUE_HOST=redis-queue
REDIS_QUEUE_PORT=6379
REDIS_PUBSUB_HOST=redis-pubsub
REDIS_PUBSUB_PORT=6379
REDIS_PASSWORD=shoujiki_v3_secure_redis_2026

# --- Sandbox ---
# Internal Docker network URL
SANDBOX_URL=http://sandbox:8001

# --- Solana Infrastructure ---
# Use a high-performance RPC (Helius, QuickNode, Triton) for devnet.
SOLANA_RPC_URL=https://api.devnet.solana.com

# The Squads V4 Program ID. 
# Standard: SQDS4Byj9s7BfR7atvH9iSnduXW1U9CAdX9rW5L2S8X
SQUADS_PROGRAM_ID=SQDS4Byj9s7BfR7atvH9iSnduXW1U9CAdX9rW5L2S8X

# The PDA of your Squads Multisig Vault. 
SQUADS_MULTISIG_PDA=SQDS_PLATFORM_MULTISIG_ADDRESS_CHANGE_ME

# --- Platform Authority (Custodial L2 Model) ---
# A secure string used as a seed to derive the Master Platform Wallet.
# This wallet holds all funds for the Layer 2 internal billing system.
PLATFORM_SECRET_SEED=shoujiki_platform_secret_seed_32_chars

# --- Security ---
# Secret key for JWT token generation.
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
