# -----------------------------------------------------------------------------
# SHOUJIKI BACKEND (API) CONFIGURATION
# -----------------------------------------------------------------------------

# --- Database ---
# Local Docker default: postgresql+asyncpg://shoujiki:shoujiki@db:5432/shoujiki
# Production: Use a managed PostgreSQL instance (Supabase, Neon, etc.)
DATABASE_URL=postgresql+asyncpg://shoujiki:shoujiki@db:5432/shoujiki

# --- Sandbox ---
# Internal Docker network URL
SANDBOX_URL=http://sandbox:8001

# --- Solana Infrastructure ---
# Use a high-performance RPC (Helius, QuickNode, Triton) for devnet/devnet.
# Public RPCs will cause payment verification failures.
SOLANA_RPC_URL=https://api.devnet.solana.com

# The Squads V4 Program ID. 
# Standard: SQDS4Byj9s7BfR7atvH9iSnduXW1U9CAdX9rW5L2S8X
SQUADS_PROGRAM_ID=SQDS4Byj9s7BfR7atvH9iSnduXW1U9CAdX9rW5L2S8X

# The PDA of your Squads Multisig Vault. 
# You must create this at app.squads.so and add the Platform Wallet as a member.
SQUADS_MULTISIG_PDA=your_squads_multisig_pda_here

# --- Platform Authority ---
# A secure, 32-character string used as a seed to derive the Platform Wallet.
# CRITICAL: Do not change this after funding the derived wallet.
PLATFORM_SECRET_SEED=shoujiki_platform_secret_seed_32_chars

# --- Security ---
# Secret key for JWT token generation. Use 'openssl rand -hex 32' to generate.
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
